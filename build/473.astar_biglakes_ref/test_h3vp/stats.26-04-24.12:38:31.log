=== VALUE PREDICTOR =============================================================

PREDICTOR       = H3VP (History-Based Highly Reliable Hybrid)
H3VP_Q_SIZE     = 128
H3VP_ORACLE_CONF= 0
H3VP_INDEX_BITS = 10
H3VP_TAG_BITS   = 10
H3VP_CONF1      = 10
H3VP_CONF2      = 112
VP_TABLE_BYTES  = 38272
Cost Accounting
	One H3VP entry:
		tag:             10 bits
		hist0+hist1+hist2: 192 bits
		diff:            64 bits
		instance ctr:    7 bits
		num_ret:         2 bits
		conf per pred (x3): 7 bits each
		failed flags:    3 bits
		bits/H3VP entry: 299 bits
	Total storage cost = 1024 entries x 299 bits = 306176 bits
VP_PRED_INT_ALU = 1
VP_PRED_FP_ALU  = 0
VP_PRED_LOAD    = 1

